    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "prisma": {
    "seed": "tsx --env-file=.env.local prisma/seed.ts"
  },
  "dependencies": {
