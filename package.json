    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.3",
    "exceljs": "^4.4.0",
    "googleapis": "^173.0.0",
    "ioredis": "^5.11.1",
    "isomorphic-dompurify": "^3.3.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^8.0.10",
    "pg": "^8.21.0",
